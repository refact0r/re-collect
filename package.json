		"vite": "^8.0.3",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.80.0"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.4",
		"@convex-dev/r2": "^0.9.1",
		"@fontsource/dm-mono": "^5.2.7",
		"@fontsource/dm-sans": "^5.2.8",
		"convex": "^1.34.1",
		"convex-svelte": "^0.0.12",
		"fractional-indexing": "^3.2.0"
	}
